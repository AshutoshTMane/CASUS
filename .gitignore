# ========== Python Backend ==========
venv/                # Ignore virtual environment
__pycache__/         # Ignore compiled Python files
*.pyc                # Ignore Python cache files
.env                 # Ignore environment variables

# ========== Flutter Specific ==========
flutter_app/.dart_tool/            # Ignore Dart tool-specific files
flutter_app/.idea/                 # Ignore JetBrains project settings
flutter_app/.vscode/               # Ignore VS Code settings
flutter_app/.packages  # Ignore Flutter package files
flutter_app/.flutter-plugins  # Ignore Flutter plugin-related files
flutter_app/.flutter-plugins-dependencies  # Ignore Flutter plugin dependencies
flutter_app/test/                  # Ignore Flutter test folder
flutter_app/android/              # Ignore Android platform files
flutter_app/ios/                  # Ignore iOS platform files
flutter_app/linux/                # Ignore Linux platform files
flutter_app/macos/                # Ignore macOS platform files
flutter_app/web/                  # Ignore Web platform files
flutter_app/windows/              # Ignore Windows platform files
flutter_app/flutter_app.iml       # Ignore IntelliJ project file


# ========== IDE and System Files ==========
.vscode/             # VS Code settings
.idea/               # JetBrains IDE settings
.DS_Store            # macOS system file
Thumbs.db            # Windows system file
