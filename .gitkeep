# For backend virtual environment (ignored in .gitignore but should exist)
mkdir -p backend/venv && touch backend/venv/.gitkeep

# For Flutter app directory (ignored in .gitignore but should exist)
mkdir -p flutter_app && touch flutter_app/.gitkeep

# For Flutter lib directory (ignored in .gitignore but should exist)
mkdir -p flutter_app/lib && touch flutter_app/lib/.gitkeep

# For database folder (if applicable)
mkdir -p backend/database && touch backend/database/.gitkeep

# For logs (if you want logs folder structure)
mkdir -p backend/logs && touch backend/logs/.gitkeep
